{
  "appId": "com.pratyushmaharjan.beatnest",
  "appName": "BeatNest",
  "webDir": "build",
  "server": {
    "androidScheme": "https"
  },
  "plugins": {
    "SplashScreen": {
      "launchShowDuration": 2000,
      "backgroundColor": "#06060a",
      "showSpinner": false,
      "androidSpinnerStyle": "none",
      "iosSpinnerStyle": "none",
      "splashFullScreen": true,
      "splashImmersive": true
    },
    "StatusBar": {
      "style": "DARK",
      "backgroundColor": "#06060a"
    }
  }
}
